}
area[landuse=village_green] {
    fill-color: green#b1e0c2;
    width: 1;
}
area[landuse=recreation_ground] {
    fill-color: green#b1e0c2;
    width: 1;
}
node[landuse] {
    icon-image: "presets/misc/deprecated.svg";
