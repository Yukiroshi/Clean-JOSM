relation[natural=grassland] >[role=outer] way {
    fill-color: grassland#8cD05F;
}
area[natural=grassland]::fill{
    fill-image: "https://raw.githubusercontent.com/Yukiroshi/Clean-JOSM/refs/heads/main/grassland.svg";
}
area[natural=wetland],
relation[natural=wetland] >[role=outer] way {
