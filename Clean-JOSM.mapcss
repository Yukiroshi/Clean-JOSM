}
area[landuse=aquaculture] {
    fill-color: aquaculture#189dff;
    width: 1;
}
area[landuse=grass]{
    fill-color: grass#5dca19;
    width: 1;
}
area[landuse=grass]::fill{
    fill-image: "https://raw.githubusercontent.com/Yukiroshi/Clean-JOSM/refs/heads/main/grassland.svg";
}
