    width: 4 * prop(zoom);
    color: wood#077e07;
}
area[natural=wood],
relation[natural=wood] >[role=outer] way,
area[landuse=forest],
relation[landuse=forest] >[role=outer] way {
    fill-color: wood#077e07;
    width: 2 * prop(zoom);
}
