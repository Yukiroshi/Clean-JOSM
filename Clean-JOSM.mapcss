    width: 1 * prop(zoom);
    color: natural#8CD05F;
}
way[natural=valley] {
    width: 1 * prop(zoom);
    color: natural#8CD05F;
}
area[natural=scree],
relation[natural=scree] >[role=outer] way {
    fill-color: scree#c3c3c3;
}
area[natural=shingle],
relation[natural=shingle] >[role=outer] way {
    fill-color: shingle#c3c3c3;
}
