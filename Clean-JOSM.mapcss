}
area[junction=yes] {
    fill-color: junction#c0c0c0;
}

node[highway=street_lamp] {
  icon-image: "https://raw.githubusercontent.com/rapideditor/temaki/refs/heads/main/icons/street_lamp_arm.svg";
}
node[highway=speed_camera] {
  icon-image: "https://raw.githubusercontent.com/rapideditor/temaki/refs/heads/main/icons/security_camera.svg";
}
node[highway=toll_gantry] {
  icon-image: "https://raw.githubusercontent.com/rapideditor/temaki/refs/heads/main/icons/toll_gantry.svg";
}
node[highway=crossing] {
  icon-image: "https://raw.githubusercontent.com/rapideditor/temaki/refs/heads/main/icons/pedestrian_crosswalk.svg";
}
node[crossing=traffic_signals] {
  icon-image: "https://raw.githubusercontent.com/rapideditor/temaki/refs/heads/main/icons/traffic_signals.svg";
}
node[traffic_calming=hump] {
  icon-image: "https://raw.githubusercontent.com/rapideditor/temaki/refs/heads/main/icons/speed_hump.svg";
}
node[traffic_calming=bump] {
  icon-image: "https://raw.githubusercontent.com/rapideditor/temaki/refs/heads/main/icons/speed_bump.svg";
}
node[traffic_calming=mini_bumps] {
  icon-image: "https://raw.githubusercontent.com/rapideditor/temaki/refs/heads/main/icons/rumble_strip.svg";
}
node[traffic_calming=dip] {
  icon-image: "https://raw.githubusercontent.com/rapideditor/temaki/refs/heads/main/icons/speed_dip.svg";
}
node[traffic_calming=chicane] {
  icon-image: "https://raw.githubusercontent.com/rapideditor/temaki/refs/heads/main/icons/chicane_arrow.svg";
}

/*Railways*/

node[railway=buffer_stop] {
  icon-image: "https://raw.githubusercontent.com/rapideditor/temaki/refs/heads/main/icons/buffer_stop.svg";
}
node[railway=tram_stop] {
  icon-image: "https://raw.githubusercontent.com/rapideditor/temaki/refs/heads/main/icons/board_tram.svg";
}
node[railway=signal] {
  icon-image: "https://raw.githubusercontent.com/rapideditor/temaki/refs/heads/main/icons/railway_signals.svg";
}
way > node[railway=tram_level_crossing] {
  icon-image: "https://raw.githubusercontent.com/rapideditor/temaki/refs/heads/main/icons/x_oblique.svg";
  icon-rotation: parent_way_angle();
}

/*Infrastracture*/

area[building][!building?!][building!=y][building!=1] {
    fill-color: building#e06e5f;
}
area[building=roof],
area[building][!building?!][wall?!],
area[building:part][!building:part?!] {
    fill-color: buildingpart#dcbbbb;
}

node[building],
area[building] {
  icon-image: "https://raw.githubusercontent.com/Yukiroshi/MakiMaki/refs/heads/main/icons/building.svg";
}
node[building][building:levels>=10],
area[building][building:levels>=10] {
  icon-image: "https://raw.githubusercontent.com/Yukiroshi/MakiMaki/refs/heads/main/icons/building-high.svg";
}

node[entrance][entrance!=no] {
  icon-image: "https://raw.githubusercontent.com/mapbox/maki/refs/heads/main/icons/entrance-alt1.svg";
}

/*Man made*/

way[bridge=yes]::core_bridge,
way[bridge=viaduct]::core_bridge,
way[bridge=swing]::core_bridge,
way[bridge=movable]::core_bridge,
way[bridge=cantilever]::core_bridge,
way[bridge=covered]::core_bridge,
way[bridge=low_water_crossing]::core_bridge,
way[bridge=trestle]::core_bridge,
way[bridge=aqueduct]::core_bridge {
    major-z-index: 2;
    object-z-index: -1;
    width: +10;
    color: bridge#000000;
    opacity: 0.8;
}
way[tunnel=yes]::core_tunnel,
way[tunnel=culvert]::core_tunnel,
way[tunnel=building_passage]::core_tunnel,
way[tunnel=avalanche_protector]::core_tunnel {
    major-z-index: 2;
    object-z-index: -1;
    width: 2;
    color: tunnel#964B00;
    opacity: 0.5;
}

node[man_made=surveillance] {
  icon-image: "https://raw.githubusercontent.com/rapideditor/temaki/refs/heads/main/icons/security_camera.svg";
}
node[tower:type=lighting] {
  icon-image: "https://raw.githubusercontent.com/rapideditor/temaki/refs/heads/main/icons/mast_lighting.svg";
}
node[waterway=milestone],
node[highway=milestone],
node[railway=milestone] {
  icon-image: "https://raw.githubusercontent.com/rapideditor/temaki/refs/heads/main/icons/milestone.svg";
}

area[landuse],
area[leisure],
area[amenity],
area[place],
