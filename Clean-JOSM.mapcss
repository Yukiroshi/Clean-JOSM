relation[natural=scrub] >[role=outer] way  {
    fill-color: scrub#51a10a;
    width: 1.5 * prop(zoom);
}
area[natural=scrub]::fill {
    fill-image: "https://raw.githubusercontent.com/Yukiroshi/Clean-JOSM/refs/heads/main/pattern-scrub.svg";
}
area[natural=fell],
relation[natural=scfellrub] >[role=outer] way {
    fill-color: natural#002f00;
}
area[natural=heath],
relation[natural=heath] >[role=outer] way {
    fill-color: heath#dddfc0;
}
