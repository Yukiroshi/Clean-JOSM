    icon-image: "https://raw.githubusercontent.com/Yukiroshi/MakiMaki/refs/heads/main/icons/bust.svg";
}
node[tourism=gallery] {
    icon-image: "presets/sightseeing/gallery.svg";
}
node[tourism=museum] {
    icon-image: "presets/sightseeing/museum.svg";
}



