    repeat-image: "presets/misc/cliff_pattern.svg";
    repeat-image-align: top;
    width: 1 * prop(zoom);
    color: #b2b2b2;
}
node[natural=cliff] {
    icon-image: "presets/misc/cliff.svg";
}
