/*****************/
/* military tags */
/*****************/



area[military=airfield],
area[military=bunker],
area[military=barracks],
area[military=danger_area],
area[military=range] {
    fill-color: military#b62c2c;
}
node[military=airfield] {
    icon-image: "presets/transport/airport/airfield.svg";
}
node[military=bunker] {
    icon-image: "presets/landmark/bunker.svg";
}
node[military=barracks][!is_prop_set(icon-image)] {
    icon-image: "presets/misc/no_icon.svg";
}
node[military=danger_area] {
    icon-image: "presets/misc/danger.svg";
}
node[military=range] {
    icon-image: "presets/sport/range.svg";
}



/****************/
/* railway tags */
/****************/



area[railway=station] {
    fill-color: railwaypoint#f7efb7;
}
node[railway=station] {
    icon-image: "presets/transport/railway_station.svg";
}
node[railway=halt] {
    icon-image: "presets/transport/railway_halt.svg";
}
node[railway=tram_stop] {
    icon-image: "presets/transport/tram.svg";
}
node[railway=subway_entrance] {
    icon-image: "presets/transport/underground.svg";
}
node[railway=crossing] {
    icon-image: "presets/transport/railway/crossing.svg";
}
node[railway=level_crossing] {
    icon-image: "presets/transport/railway/level_crossing.svg";
}
way[railway=rail][!tunnel] {
    width: 2;
    color: rail#ddd;
    dashes: 12,12;
    dashes-background-color: raildashed#555555;
    casing-width: 2;
}
way[railway=rail][tunnel] {
    width: 2;
    color: rail#656565;
    dashes: 12,12;
    dashes-background-color:#2A2A2A;
    casing-width: 2;
}

/* draw tram on top of other way (highway=*) or
   as a standalone style */
way[highway][railway=tram]::core_railway,
way[!highway][railway=tram][!tunnel] {
    object-z-index: 1;
    modifier: false; /* don't draw default way if there is no line on default layer */
    width: 2;
    color: rail#ddd;
    dashes: 12,12;
    dashes-background-color: raildashed#555555;
    casing-width: 2;
}
way[!highway][railway=tram][tunnel] {
    object-z-index: 1;
    modifier: false; /* don't draw default way if there is no line on default layer */
    width: 2;
    color: rail##B9B7B5;
    dashes: 12,12;
    dashes-background-color: raildashed#A3A19E;
    casing-width: 2;
}
way[railway=light_rail][!tunnel] {
    width: 2;
    color: rail#ddd;
    dashes: 12,12;
    dashes-background-color: raildashed#555555;
    casing-width: 2;
}
 way[railway=light_rail][tunnel]{
    width: 2;
    color: rail#656565;
    dashes: 12,12;
    dashes-background-color: raildashed#2a2a2a;
    casing-width: 2;
}
way[railway=subway][!tunnel] {
    width: 2;
    color: rail#ddd;
    dashes: 12,12;
    dashes-background-color: raildashed#333;
    casing-width: 2;
}
way[railway=subway][tunnel] {
    width: 2;
    color: rail#444;
    dashes: 12,12;
    dashes-background-color: raildashed#111111;
    casing-width: 2;
}

way[railway=preserved][!tunnel] {
    width: 2;
    color: oldrail#ddd;
    dashes: 9,9;
    dashes-background-color: raildashed#555555;
    casing-width: 2;
}
way[railway=preserved][tunnel] {
    width: 2;
    color: oldrail#C2C2C2;
    dashes: 9,9;
    dashes-background-color: raildashed#404040;
    casing-width: 2;
}
way[railway=rail][service=crossover][!tunnel],
way[railway=rail][service=siding][!tunnel],
way[railway=rail][service=yard][!tunnel],
way[railway=rail][service=spur][!tunnel],
way[!highway][railway=tram][service=crossover][!tunnel],
way[!highway][railway=tram][service=siding][!tunnel],
way[!highway][railway=tram][service=yard][!tunnel],
way[!highway][railway=tram][service=spur][!tunnel],
way[railway=light_rail][service=crossover][!tunnel],
way[railway=light_rail][service=siding][!tunnel],
way[railway=light_rail][service=yard][!tunnel],
way[railway=light_rail][service=spur][!tunnel],
way[railway=subway][service=crossover][!tunnel],
way[railway=subway][service=siding][!tunnel],
way[railway=subway][service=yard][!tunnel],
way[railway=subway][service=spur][!tunnel],
way[railway=preserved][service=crossover][!tunnel],
way[railway=preserved][service=siding][!tunnel],
way[railway=preserved][service=yard][!tunnel],
way[railway=preserved][service=spur][!tunnel] {
    width: 2;
    color: rail#ddd;
    dashes: 12,12;
    dashes-background-color: raildashed#ddccaa;
    opacity: 2;
}
way[railway=rail][service=crossover][tunnel],
way[railway=rail][service=siding][tunnel],
way[railway=rail][service=yard][tunnel],
way[railway=rail][service=spur][tunnel],
way[!highway][railway=tram][service=crossover][tunnel],
way[!highway][railway=tram][service=siding][tunnel],
way[!highway][railway=tram][service=yard][tunnel],
way[!highway][railway=tram][service=spur][tunnel],
way[railway=subway][service=crossover][tunnel],
way[railway=subway][service=siding][tunnel],
way[railway=subway][service=yard][tunnel],
way[railway=subway][service=spur][tunnel],
way[railway=light_rail][service=crossover][tunnel],
way[railway=light_rail][service=siding][tunnel],
way[railway=light_rail][service=yard][tunnel],
way[railway=light_rail][service=spur][tunnel],
way[railway=subway][service=crossover][tunnel],
way[railway=subway][service=siding][tunnel],
way[railway=subway][service=yard][tunnel],
way[railway=subway][service=spur][tunnel],
way[railway=preserved][service=crossover],
way[railway=preserved][service=siding][tunnel],
way[railway=preserved][service=yard][tunnel],
way[railway=preserved][service=spur][tunnel] {
    width: 2;
    color: rail#333;
    dashes: 12,12;
    dashes-background-color: raildashed#676257;
    opacity: 2;
}

/* disused often appears together with highway=xy */
/* -> draw on separate layer with higher z-index, but use */
/* modifier: false; to suppress default line when used alone. */
/* use default layer when used without highway=* to display bridge correctly */
way[railway=disused][highway]::core_railway,
way[railway=disused][!highway][!tunnel] {
    width: 2;
    color: rail#eeeeee;
    dashes: 12,12;
    dashes-background-color: raildashed#808080;
    casing-width: 2;
}
way[railway=disused][!highway][tunnel] {
    width: 2;
    color: rail#747474;
    dashes: 12,12;
    dashes-background-color:#404040;
    casing-width: 2;
}

way[railway=abandoned][highway]::core_railway,
way[railway=abandoned][!highway] {
    width: 1;
    modifier: false;
    z-index: 1;
    color: oldrail#404040;
    dashes: 9,9;
}
way[railway=narrow_gauge],
way[railway=monorail] {
    width: 1;
    color: rail#404040;
    dashes: 9,9;
}
way[railway=narrow_gauge][service=crossover],
way[railway=narrow_gauge][service=siding],
way[railway=narrow_gauge][service=yard],
way[railway=narrow_gauge][service=spur],
way[railway=monorail][service=crossover],
way[railway=monorail][service=siding],
way[railway=monorail][service=yard],
way[railway=monorail][service=spur] {
    dashes: 6,6;
}
area[railway=turntable] {
    fill-color: rail#404040;
}
node[railway=turntable] {
    icon-image: "presets/transport/railway/turntable.svg";
}
node[railway=buffer_stop] {
    icon-image: "presets/transport/railway/buffer_stop.svg";
}
area[railway=platform]:closed {
    fill-color: rail#404040;
}
way[railway=platform] {
    width: 2;
    color: rail#404040;
}
way[railway=funicular] {
    width: 1;
    color: rail#404040;
    dashes: 9,9;
}
node[railway=switch] {
