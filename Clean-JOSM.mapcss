}
area[natural=water][!is_prop_set("fill-color")],
relation[natural=water][!is_prop_set("fill-color")] >[role=outer] way[!is_prop_set("fill-color")] {
    fill-color: water#77d3ee;
}
area[natural=water]::fill {
    fill-image: "https://raw.githubusercontent.com/Yukiroshi/Clean-JOSM/refs/heads/main/pattern-waves.svg";
}
area[natural=water][intermittent=yes] {
    width: 2 * prop(zoom);
    dashes: 15, 5;
}
way[natural=coastline] {
    width: 2.5 * prop(zoom);
    color: coastline#54e262;
    dashes: 5,3;
    z-index: 5;
    right-casing-color: coastline#4ee9d6;
    right-casing-width: 8 * prop(zoom);
    right-casing-opacity: 0.35;
}
